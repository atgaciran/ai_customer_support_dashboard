# ──────────────────────────────────────────────────────────────
# io.net API Configuration
# ──────────────────────────────────────────────────────────────
# These environment variables configure the connection to the io.net
# inference API, which provides the AI-powered reply suggestion feature.
#
# IONET_BASE_URL  → Base URL for the io.net API (OpenAI-compatible endpoint)
# IONET_API_KEY   → Your personal API key (obtain from io.net dashboard)
# IONET_MODEL     → The LLM model identifier to use for text generation
# ──────────────────────────────────────────────────────────────

# Base URL for the io.net inference API
IONET_BASE_URL=https://api.intelligence.io.solutions/api/v1

# API key for authentication — keep this secret and never commit to version control
IONET_API_KEY= 

# LLM model to use for generating AI reply suggestions
IONET_MODEL=meta-llama/Llama-3.3-70B-Instruct